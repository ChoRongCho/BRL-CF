\newlabel{method:KB}{{\mbox  {IV-B}1}{6}}
\@writefile{toc}{\contentsline {subsubsection}{\numberline {\mbox  {IV-B}2}Planning Manager}{6}{}\protected@file@percent }
\newlabel{method:PM}{{\mbox  {IV-B}2}{6}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Planning Manager workflow. The PM maintains a belief over symbolic possible worlds, updates it using observations, and evaluates belief uncertainty. If uncertainty exceeds a threshold, the PM requests verification through the FM. Otherwise, it commits the most probable hypothesis to the KB and continues planning and execution.\relax }}{7}{}\protected@file@percent }
\newlabel{fig:pm}{{4}{7}}
